# =============================================================================
# WOPR Platform UI — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values for your environment.
#
#   cp .env.example .env.local
#
# Next.js loads .env.local automatically. Variables prefixed with NEXT_PUBLIC_
# are exposed to the browser bundle. See:
# https://nextjs.org/docs/app/building-your-application/configuring/environment-variables

# -----------------------------------------------------------------------------
# API Configuration
# -----------------------------------------------------------------------------

# Base URL of the WOPR platform API (wopr-network/wopr-platform).
# The UI derives all REST endpoints from this value (see src/lib/api-config.ts).
# In development this defaults to http://localhost:3001 if unset.
#
# PRODUCTION: Must be a public HTTPS URL (e.g. https://api.wopr.bot).
# Internal or Docker hostnames (platform-api, localhost, 10.x.x.x) will be
# rejected at startup — they leak network topology and break browser calls.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Canonical site URL for SEO metadata (sitemap, OG tags, robots.txt).
# Defaults to https://wopr.bot if unset. Must NOT have a trailing slash.
# NEXT_PUBLIC_SITE_URL=https://wopr.bot

# -----------------------------------------------------------------------------
# Pre-Launch Configuration
# -----------------------------------------------------------------------------

# Launch date for the pre-launch teaser page. Before this date, wopr.bot shows
# a blinking cursor and countdown instead of the full landing page.
# Format: ISO 8601. Default: 2026-04-01T00:00:00Z
# NEXT_PUBLIC_LAUNCH_DATE=2026-04-01T00:00:00Z

# -----------------------------------------------------------------------------
# Stripe
# -----------------------------------------------------------------------------

# Stripe publishable key for client-side payment collection.
# Used in onboarding billing step and billing/payment page.
# Get it from https://dashboard.stripe.com/apikeys
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
